{
  "name": "@meeting-calendar/server",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun run typecheck && esbuild src/index.ts --bundle --platform=node --format=esm --sourcemap --outfile=dist/index.js --packages=external --alias:@meeting-calendar/shared=../../packages/shared/src/index.ts",
    "start": "bun dist/index.js"
  },
  "dependencies": {
    "@meeting-calendar/shared": "*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "esbuild": "^0.25.0"
  }
}
