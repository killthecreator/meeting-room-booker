{
  "name": "@meeting-calendar/root",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:client": "bun run -F @meeting-calendar/client dev",
    "dev:server": "bun run -F @meeting-calendar/server dev",
    "dev": "concurrently -n client,server -c blue,magenta \"bun run dev:client\" \"bun run dev:server\"",
    "build:client": "bun run -F @meeting-calendar/client build",
    "build:server": "bun run -F @meeting-calendar/server build",
    "build": "bun run build:server && bun run build:client",
    "start:client": "bun run -F @meeting-calendar/client start",
    "start:server": "bun run -F @meeting-calendar/server start",
    "start": "concurrently -n client,server -c blue,magenta \"bun run start:client\" \"bun run start:server\"",
    "lint": "eslint .",
    "prettier": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0"
  }
}
