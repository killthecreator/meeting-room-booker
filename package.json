{
  "name": "@meeting-calendar/root",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:client": "npm run dev --workspace=@meeting-calendar/client",
    "dev:server": "npm run dev --workspace=@meeting-calendar/server",
    "dev": "concurrently -n client,server -c blue,magenta \"npm run dev:client\" \"npm run dev:server\"",
    "build:client": "npm run build --workspace=@meeting-calendar/client",
    "build:server": "npm run build --workspace=@meeting-calendar/server",
    "build": "npm run build:server && npm run build:client",
    "start:client": "npm run start --workspace=@meeting-calendar/client",
    "start:server": "npm run start --workspace=@meeting-calendar/server",
    "start": "concurrently -n client,server -c blue,magenta \"npm run start:client\" \"npm run start:server\"",
    "lint": "eslint .",
    "prettier": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0"
  }
}
