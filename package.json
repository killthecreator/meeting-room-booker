{
  "name": "haptiq-meeting-calendar",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev:client": "vite",
    "dev:server": "tsx --watch --env-file=.env src/server/index.ts",
    "dev": "npm run dev:client && npm run dev:server",
    "build": "tsc -b && vite build",
